{
  "name": "imlfootballchallenge",
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test-api": "node --test",
    "test": "vitest run",
    "serve-local": "ng serve --host 0.0.0.0",
    "build-cloud": "ng build --base-href /browser/",
    "build-prod": "ng build --base-href /wcc-26/",
    "start:api": "node server.mjs",
    "dev": "concurrently \"npm run start\" \"npm run start:api\"",
    "dev:ssr": "concurrently \"ng run imlfootballapp:serve-ssr\" \"npm run start:api\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.4",
    "@angular/cdk": "^22.0.2",
    "@angular/common": "^22.0.4",
    "@angular/compiler": "^22.0.4",
    "@angular/core": "^22.0.4",
    "@angular/forms": "^22.0.4",
    "@angular/platform-browser": "^22.0.4",
    "@angular/platform-browser-dynamic": "^22.0.6",
    "@angular/platform-server": "^22.0.6",
    "@angular/router": "^22.0.4",
    "@angular/service-worker": "^22.0.4",
    "@angular/ssr": "^22.0.6",
    "@types/express": "^4.17.25",
    "@upstash/qstash": "^2.11.1",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.1.3",
    "express": "^4.22.2",
    "fuse.js": "^7.4.2",
    "itty-router": "^5.0.24",
    "ngx-cookie-service": "^22.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.6.3",
    "@analogjs/vitest-angular": "^2.6.3",
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.4",
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "istanbul-lib-instrument": "^6.0.3",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "shx": "^0.4.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
