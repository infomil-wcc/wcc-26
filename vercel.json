{
  "version": 2,
  "build": {
    "env": {
      "NG_CLI_ANALYTICS": "false"
    }
  },
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/match-scheduler",
      "destination": "/api/match-scheduler.mjs"
    },
    {
      "source": "/api/match-results",
      "destination": "/api/match-results.mjs"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/match-results.mjs": {
      "maxDuration": 60
    },
    "api/match-scheduler.mjs": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/match-scheduler",
      "schedule": "0 12 * * *"
    }
  ]
}