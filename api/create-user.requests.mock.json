{
  "valid_complete_request": {
    "description": "Complete user creation request with all fields",
    "method": "POST",
    "url": "http://localhost:3000/api/create-user",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "email": "john.doe@example.com",
      "password": "SecurePassword123!",
      "first_name": "John",
      "last_name": "Doe"
    }
  },
  "minimal_request": {
    "description": "Minimal request with only required fields (email and password)",
    "method": "POST",
    "url": "http://localhost:3000/api/create-user",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "email": "user@example.com",
      "password": "Password123!"
    }
  },
  "request_with_partial_name": {
    "description": "Request with email, password, and only first_name",
    "method": "POST",
    "url": "http://localhost:3000/api/create-user",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "email": "jane.smith@example.com",
      "password": "AnotherPassword456!",
      "first_name": "Jane"
    }
  },
  "invalid_missing_email": {
    "description": "Invalid - missing required email field",
    "method": "POST",
    "url": "http://localhost:3000/api/create-user",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "password": "Password123!",
      "first_name": "John",
      "last_name": "Doe"
    },
    "expected_error": 400
  },
  "invalid_missing_password": {
    "description": "Invalid - missing required password field",
    "method": "POST",
    "url": "http://localhost:3000/api/create-user",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "email": "john@example.com",
      "first_name": "John",
      "last_name": "Doe"
    },
    "expected_error": 400
  }
